DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=test_db
DB_USERNAME=root
DB_PASSWORD=

# ALLOWED_ORIGIN=chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef, http://localhost:3000
ALLOWED_ORIGIN=*
# Only set to true if the API relies on cookies/HTTP auth for cross-origin requests.
CORS_ALLOW_CREDENTIALS=false

# Generate with: php -r "echo bin2hex(random_bytes(32));"
API_SECRET_KEY=

# Enables demo/debug-only routes (e.g. /db-test). Keep false in production.
APP_DEBUG=false
